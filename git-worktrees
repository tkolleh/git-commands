#!/bin/zsh
# vim:ft=zsh
#
# git-worktrees - fzf powered git worktree picker
#
#================================================== 
#
show_help() {
  printf -- "
git-worktrees - git worktree picker

Usage: git worktrees [OPTIONS]

Options:
  -h,     Show this help message

Description:
  FZF Powered git worktree picker.
  Writes selected path to temp file for shell hook to process.

Examples:
  git worktrees          # Show all worktrees and cd to selected
"
    exit 0
}

git-worktrees-cd() {
  local dir
  local target_file="${TMPDIR:-/tmp}/git-worktrees-cd-target"

  dir="$(source "$FZF_GIT_HOME/fzf-git.sh" --run worktrees)"

  if [[ -d "$dir" ]]; then
    printf '%s' "$dir" > "$target_file"
  fi
}

main() {
    case "$1" in
        -h|--help)
            show_help
            ;;
        *)
            git-worktrees-cd "$@"
            ;;
    esac
}

main "$@"
